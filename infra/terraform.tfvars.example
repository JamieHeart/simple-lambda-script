region      = "us-east-1"
environment = "dev"
app_name    = "simple-lambda"

executions = {
  # One-off invocation (minimal required fields)
  run_alice = {
    type     = "oneoff"
    name     = "Alice"
    greeting = "hello"
    language = "en"
    run_id   = "1"
  }

  # One-off with title (optional)
  run_bob = {
    type     = "oneoff"
    name     = "Bob"
    greeting = "buenos dias"
    language = "es"
    title    = "Dr."
    run_id   = "1"
  }

  # Cron with emoji (optional) -- fires every 5 minutes
  cron_charlie = {
    type     = "cron"
    name     = "Charlie"
    greeting = "bonjour"
    language = "fr"
    emoji    = true
    schedule = "rate(5 minutes)"
  }

  # Cron with all fields -- fires daily at 9 AM UTC
  cron_diana = {
    type     = "cron"
    name     = "Diana"
    greeting = "good morning"
    language = "en"
    title    = "Captain"
    emoji    = true
    schedule = "cron(0 9 * * ? *)"
  }
}
