region      = "us-east-1"
environment = "dev"
app_name    = "simple-lambda"

# Update this after pushing your first image to ECR
lambda_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/simple-lambda-dev:latest"

executions = {
  # One-off invocation: bump run_id to re-trigger
  run_alice = {
    type   = "oneoff"
    name   = "Alice"
    run_id = "1"
  }

  # Cron schedule: fires every 5 minutes
  cron_bob = {
    type     = "cron"
    name     = "Bob"
    schedule = "rate(5 minutes)"
  }

  # Cron schedule: fires daily at 9 AM UTC
  cron_charlie = {
    type     = "cron"
    name     = "Charlie"
    schedule = "cron(0 9 * * ? *)"
  }
}
